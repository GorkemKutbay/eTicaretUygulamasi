@model IEnumerable<eTicaretUygulamasi.Mvc.Models.ViewModels.MyProductsViewModel>

@{
    ViewData["Title"] = "Ürünlerim";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h3>Satışta Olan Ürünlerim</h3>
        <a href="/Product/Create" class="btn btn-success">Yeni Ürün Ekle</a>
    </div>
    <hr />
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Ürün No</th>
                <th>Ürün Adı</th>
                <th>Fiyat</th>
                <th>Stok Miktarı</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td>@product.ProductId</td>
                    <td>@product.ProductName</td>
                    <td>@product.Price.ToString("C2")</td>
                    <td>@product.StockQuantity Adet</td>
                    <td>
                        <a href="/Product/Edit/@product.ProductId" class="btn btn-sm btn-primary">Düzenle</a>
                        <a href="/Product/Delete/@product.ProductId" class="btn btn-sm btn-danger">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>