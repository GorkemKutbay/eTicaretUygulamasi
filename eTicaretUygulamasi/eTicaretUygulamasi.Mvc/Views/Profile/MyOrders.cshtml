@model IEnumerable<MyOrdersViewModel>


@{
    ViewData["Title"] = "Siparişlerim";
}

<div class="container mt-4">
    <h3>Sipariş Geçmişim</h3>
    <hr />
    <table class="table table-striped table-hover">
        <thead class="thead-dark">
            <tr>
                <th>Sipariş No</th>
                <th>Tarih</th>
                <th>Toplam Tutar</th>
                <th>Durum</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>#@order.OrderId</td>
                    <td>@order.OrderDate.ToShortDateString()</td>
                    <td>@order.TotalPrice.ToString("C2")</td>
                    <td>
                        <span class="badge @(order.Status == "Tamamlandı" ? "bg-success" : "bg-warning")">
                            @order.Status
                        </span>
                    </td>
                    <td>
                        <a asp-action="Details" asp-controller="Order" asp-route-id="@order.OrderId" class="btn btn-sm btn-info">Detay</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>